APP_NAME=FIRE Backend
APP_ENV=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/fire
AUTO_CREATE_SCHEMA=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=6

FIRE_COMPLIANCE_MODE=true
ENABLE_GEOCODE=true
GEOCODE_TIMEOUT_SECONDS=3
GEOCODE_RATE_LIMIT_SECONDS=1
GEOCODE_FAIL_STREAK_LIMIT=3
PER_TICKET_BUDGET_MS=10000
WORKER_POLL_INTERVAL_SECONDS=1
WORKER_MAX_ATTEMPTS=3
WORKER_RETRY_BASE_SECONDS=2
WORKER_RETRY_MAX_SECONDS=60
USE_CELERY=false
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_TIME_LIMIT_SECONDS=300
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=240

TICKETS_CSV=tickets.csv
MANAGERS_CSV=managers.csv
BUSINESS_UNITS_CSV=business_units.csv

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
